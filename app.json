{
  "expo": {
    "name": "AD Services",
    "slug": "facturation-simba",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo-app.png",
    "scheme": "factures",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/logo-app.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo-app.png",
        "backgroundColor": "#FFFFFF"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.suufiaane.factures"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/logo-light.png"
    },
    "updates": {
      "url": "https://u.expo.dev/9919a532-1e0b-4f26-81b0-25c902b6f0bb"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-mail-composer",
      "expo-updates"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "9919a532-1e0b-4f26-81b0-25c902b6f0bb"
      }
    },
    "owner": "suufiaane"
  }
}
